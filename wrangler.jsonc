{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mumblekey-blog",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": ["/zh/posts/*", "/en/posts/*", "/mcp"]
  },
  "routes": [
    {
      "pattern": "blog.mumblekey.com",
      "custom_domain": true
    }
  ]
}
