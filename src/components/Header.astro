---
import type { Lang } from '../lib/i18n';
import { t, otherLang } from '../lib/i18n';

interface Props {
  lang: Lang;
  switchPath?: string;
  switchLabel: string;
}

const { lang, switchPath, switchLabel } = Astro.props;
const current = Astro.url.pathname;

const nav = [
  { href: `/${lang}/posts/`, label: t(lang, 'nav.posts') },
  { href: `/${lang}/demos/`, label: t(lang, 'nav.demos') },
  { href: `/${lang}/about/`, label: t(lang, 'nav.about') },
];

const switchText = lang === 'zh' ? 'EN' : '中文';
const fallbackSwitch = `/${otherLang(lang)}/`;
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href={`/${lang}/`}>MumbleKey<span style="color: var(--accent)">Blog</span></a>
    <nav>
      {nav.map((item) => (
        <a href={item.href} aria-current={current.startsWith(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
      <a class="icon-btn" href={switchPath ?? fallbackSwitch} aria-label={switchLabel} rel="alternate">
        {switchText}
      </a>
      <button class="icon-btn" id="theme-toggle" aria-label={t(lang, 'a11y.themeToggle')}>
        <span class="theme-icon-light">☀️</span>
        <span class="theme-icon-dark">🌙</span>
      </button>
    </nav>
  </div>
</header>

<style is:global>
  [data-theme='light'] .theme-icon-light {
    display: none;
  }
  [data-theme='dark'] .theme-icon-dark {
    display: none;
  }
</style>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
